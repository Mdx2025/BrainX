#!/usr/bin/env bash
set -euo pipefail

SOURCE_PATH="$0"
if command -v readlink >/dev/null 2>&1; then
  SOURCE_PATH="$(readlink -f "$0" 2>/dev/null || echo "$0")"
fi
ROOT="$(cd "$(dirname "$SOURCE_PATH")" && pwd)"

# Source local .env (overrides inherited env to ensure correct DATABASE_URL)
if [ -f "$ROOT/.env" ]; then
  set -a
  source "$ROOT/.env"
  set +a
fi

# Keep CLI output clean (dotenv@17 prints tips unless quiet)
export DOTENV_CONFIG_QUIET="${DOTENV_CONFIG_QUIET:-true}"

CMD="${1:-}"
shift || true

case "$CMD" in
  health)
    node "$ROOT/tests/smoke.js"
    ;;
  add|fact|facts|feature|features|search|inject|feedback|resolve|promote-candidates|lifecycle-run|metrics|runtime-report|doctor|fix|--fix|advisory|advisory-feedback|eidos|wiki)
    node "$ROOT/lib/cli.js" "$CMD" "$@"
    ;;
  distill)
    node "$ROOT/scripts/auto-distiller.js" "$@"
    ;;
  knowledge-import)
    node "$ROOT/scripts/import-knowledge-md.js" "$@"
    ;;
  knowledge-sync|knowledge-refresh)
    node "$ROOT/scripts/knowledge-sync.js" "$@"
    ;;
  knowledge-locate|knowledge-locator)
    node "$ROOT/scripts/knowledge-locate.js" "$@"
    ;;
  knowledge-new)
    node "$ROOT/scripts/new-knowledge-topic.js" "$@"
    ;;
  knowledge-seed)
    node "$ROOT/scripts/seed-knowledge-library.js" "$@"
    ;;
  knowledge-auto-sync)
    node "$ROOT/scripts/sync-knowledge-auto-blocks.js" "$@"
    ;;
  consolidate|consolidation)
    node "$ROOT/scripts/memory-consolidator.js" "$@"
    ;;
  *)
    node "$ROOT/lib/cli.js" --help
    exit 1
    ;;
esac
